parameters:
    level: 2
    paths:
        - src
    excludePaths:
        - src/Http/routes.php
    reportUnmatchedIgnoredErrors: false
    parallel:
        maximumNumberOfProcesses: 1
        processTimeout: 600.0
    bootstrapFiles:
        - phpstan-bootstrap.php
    ignoreErrors:
        - '/Call to an undefined method.*toMsegat/'
        - '/Call to an undefined method.*routesAreCached/'
